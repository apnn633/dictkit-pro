# 远程数据仓库位置（构建时注入，运行时 config.ts 用它回退加载配置与数据）
#
# 本地开发无需配置——data/ 目录存在时优先用本地；
# 也可在 data/dicts.json 的 dataSources 里配置 CDN 外链作为运行时数据源。
#
# 发行版（GitHub Pages 部署）若不配置此项，将仅依赖本地 data/ 目录
# （发布版通常无数据，需自行部署数据仓库并通过此变量指向）。
#
# ⚠️ 请确保你有权分发所指向的数据仓库内容。若数据受版权保护，请勿配置。
VITE_REMOTE_OWNER=
VITE_REMOTE_REPO=
VITE_REMOTE_BRANCH=main
VITE_REMOTE_BASEPATH=data
